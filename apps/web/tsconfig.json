{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/* 2.ts",
    "**/* 3.ts",
    "**/* 2.tsx",
    "**/* 3.tsx",
    "**/* 2.json",
    "**/* 3.json",
    "**/* 2.md",
    "**/* 3.md",
    "**/* 2.sql",
    "**/* 3.sql"
  ]
}
